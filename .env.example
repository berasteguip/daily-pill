# Copy this file to `.env` and fill in your own keys.
# This file is checked into source control to provide a template.
# Actual secrets should live in `.env`, which is ignored by git.

# API key for Google/GenAI Gemini client
GENAI_API_KEY=

# Telegram bot token and chat ID used by sender.Sender
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
